<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Inter:wght@300;400;500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
:root{
  --g:#1e2e26;--gd:#16231c;--gm:#243829;
  --cr:#f5f0e4;--crd:#e8e0cc;
  --au:#c7a878;--aul:#d8bc96;--aud:#a07f4a;
  --wh:#fdfcf8;--ink:#0f1c14;
  --mu:rgba(245,240,228,0.65)
}
body{font-family:'Inter',Helvetica,Arial,sans-serif;background:var(--gd);color:var(--wh);overflow-x:hidden}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:300;height:76px;display:flex;align-items:center;justify-content:space-between;padding:0 64px;background:rgba(22,35,28,.97);backdrop-filter:blur(16px);border-bottom:1px solid rgba(199,168,120,.12)}
.nl{display:flex;gap:40px;list-style:none}
.nl a{font-family:'DM Sans',sans-serif;font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--mu);text-decoration:none;transition:color .2s}
.nl a:hover{color:var(--au)}
.nc{font-family:'DM Sans',sans-serif;font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--ink);background:var(--au);padding:11px 28px;text-decoration:none;font-weight:500;transition:background .2s}
.nc:hover{background:var(--aul)}

/* LOGO */
.logo-svg{height:64px;width:auto;display:block}
.logo-svg .logo-wordmark path{fill:#fdfcf8}

/* HERO */
.hero{min-height:100vh;background:var(--g);padding-top:76px;position:relative;overflow:hidden;display:flex;align-items:center}
.hero::before{content:'';position:absolute;inset:0;background-image:linear-gradient(rgba(199,168,120,.03) 1px,transparent 1px),linear-gradient(90deg,rgba(199,168,120,.03) 1px,transparent 1px);background-size:80px 80px;pointer-events:none}
.hero-inner{padding:120px 80px;position:relative;z-index:2;max-width:800px}
.hero-eyebrow{font-family:'DM Sans',sans-serif;font-size:10px;letter-spacing:.32em;text-transform:uppercase;color:var(--au);margin-bottom:32px;display:flex;align-items:center;gap:14px}
.hero-eyebrow::before{content:'';width:40px;height:1px;background:var(--au)}
.hero-h1{font-family:'Playfair Display',Georgia,serif;font-size:clamp(52px,7vw,96px);line-height:.92;letter-spacing:.01em;color:var(--wh);margin-bottom:16px;font-weight:700}
.hero-h1 span{color:var(--au)}
.hero-sub{font-family:'Playfair Display',Georgia,serif;font-size:clamp(22px,3vw,36px);color:rgba(253,252,248,.5);font-weight:400;margin-bottom:48px;line-height:1.3}
.hero-desc{font-family:'Inter',Helvetica,Arial,sans-serif;font-size:16px;color:var(--mu);line-height:1.9;max-width:520px;margin-bottom:56px;border-left:2px solid var(--au);padding-left:24px}
.hero-cta{display:flex;gap:20px;align-items:center;flex-wrap:wrap}
.btn-primary{font-family:'DM Sans',sans-serif;font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--ink);background:var(--au);padding:18px 52px;text-decoration:none;font-weight:500;transition:background .2s;display:inline-block}
.btn-primary:hover{background:var(--aul)}
.btn-ghost{font-family:'DM Sans',sans-serif;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--mu);border-bottom:1px solid rgba(245,240,228,.2);text-decoration:none;padding-bottom:2px;transition:all .2s}
.btn-ghost:hover{color:var(--au);border-color:var(--au)}
.hero-stats{position:absolute;right:80px;bottom:80px;display:grid;grid-template-columns:1fr 1fr;gap:1px;background:rgba(199,168,120,.15);border:1px solid rgba(199,168,120,.15);z-index:2}
.hero-stat{background:rgba(22,35,28,.9);backdrop-filter:blur(8px);padding:28px 36px}
.hero-stat-n{font-family:'Playfair Display',Georgia,serif;font-size:38px;color:var(--au);display:block;line-height:1}
.hero-stat-l{font-family:'DM Sans',sans-serif;font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:var(--mu);margin-top:6px}

/* SECTIONS */
.section-dark{background:var(--gd);padding:120px 80px}
.section-mid{background:var(--g);padding:120px 80px}
.eb{font-family:'DM Sans',sans-serif;font-size:10px;letter-spacing:.26em;text-transform:uppercase;color:var(--au);margin-bottom:16px;display:flex;align-items:center;gap:12px}
.eb::before{content:'';width:32px;height:1px;background:var(--au)}
.sh{font-family:'Playfair Display',Georgia,serif;font-size:clamp(32px,4vw,52px);font-weight:700;color:var(--wh);line-height:1.1;margin-bottom:8px;letter-spacing:.01em}

/* PROCESS */
.process-grid{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:start;margin-top:72px}
.process-steps{display:flex;flex-direction:column}
.process-step{display:grid;grid-template-columns:60px 1fr;padding:32px 0;border-top:1px solid rgba(199,168,120,.1)}
.process-step:last-child{border-bottom:1px solid rgba(199,168,120,.1)}
.ps-n{font-family:'Playfair Display',Georgia,serif;font-size:13px;color:rgba(199,168,120,.4);padding-top:3px}
.ps-n-active{color:var(--au)}
.process-step h3{font-family:'DM Sans',sans-serif;font-size:11px;letter-spacing:.18em;text-transform:uppercase;font-weight:500;color:var(--wh);margin-bottom:10px}
.process-step p{font-family:'Inter',Helvetica,Arial,sans-serif;font-size:14px;color:var(--mu);line-height:1.8}
.process-visual{position:sticky;top:100px;display:flex;flex-direction:column;gap:16px}
.pv-block{background:var(--gm);border:1px solid rgba(199,168,120,.12);padding:40px}
.pv-block h4{font-family:'DM Sans',sans-serif;font-size:9px;letter-spacing:.26em;text-transform:uppercase;color:var(--au);margin-bottom:18px}
.pv-block ul{list-style:none;display:flex;flex-direction:column;gap:10px}
.pv-block ul li{font-family:'Inter',Helvetica,Arial,sans-serif;font-size:14px;color:var(--mu);line-height:1.6;padding-left:20px;position:relative}
.pv-block ul li::before{content:'—';position:absolute;left:0;color:var(--au);font-size:11px}
.pv-price{background:rgba(199,168,120,.06);border:1px solid rgba(199,168,120,.15);padding:40px}
.pv-price h4{font-family:'DM Sans',sans-serif;font-size:9px;letter-spacing:.26em;text-transform:uppercase;color:var(--au);margin-bottom:18px}
.pv-price p{font-family:'Inter',Helvetica,Arial,sans-serif;font-size:14px;color:var(--mu);line-height:1.8;margin-bottom:8px}
.pv-price .price-note{font-size:12px;color:rgba(199,168,120,.4);font-style:italic}


/* QUOTE */
.quote-section{background:var(--gd);padding:120px 80px;text-align:center;border-top:1px solid rgba(199,168,120,.1);border-bottom:1px solid rgba(199,168,120,.1)}
.quote-section blockquote{font-family:'Playfair Display',Georgia,serif;font-size:clamp(22px,3vw,40px);font-weight:400;font-style:italic;color:var(--cr);line-height:1.55;max-width:800px;margin:0 auto 24px}
.quote-section blockquote span{color:var(--au);font-style:normal}
.quote-section cite{font-family:'DM Sans',sans-serif;font-size:10px;letter-spacing:.28em;text-transform:uppercase;color:rgba(199,168,120,.35)}

/* CTA FINAL */
.cta-final{background:var(--g);padding:140px 80px;text-align:center}
.cta-final h2{font-family:'Playfair Display',Georgia,serif;font-size:clamp(36px,5vw,64px);font-weight:700;color:var(--wh);margin-bottom:20px;line-height:1.1}
.cta-final h2 span{color:var(--au)}
.cta-final p{font-family:'Inter',Helvetica,Arial,sans-serif;font-size:16px;color:var(--mu);line-height:1.8;max-width:520px;margin:0 auto 52px}
.cta-final .btn-primary{font-size:12px;padding:20px 64px}

/* FOOTER */
footer{background:var(--gd);border-top:1px solid rgba(199,168,120,.12)}
.ft{padding:80px;display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:60px;border-bottom:1px solid rgba(199,168,120,.08)}
.fb p{font-family:'Inter',Helvetica,Arial,sans-serif;font-size:13px;color:var(--mu);line-height:1.8;margin-top:20px;max-width:260px}
.fc h4{font-family:'DM Sans',sans-serif;font-size:9px;letter-spacing:.26em;text-transform:uppercase;color:rgba(199,168,120,.35);margin-bottom:20px}
.fc ul{list-style:none;display:flex;flex-direction:column;gap:10px}
.fc a{font-family:'DM Sans',sans-serif;font-size:13px;font-weight:300;color:var(--mu);text-decoration:none;transition:color .2s}
.fc a:hover{color:var(--au)}
.fbo{padding:24px 80px;display:flex;justify-content:space-between;align-items:center}
.fbo p{font-family:'DM Sans',sans-serif;font-size:11px;letter-spacing:.06em;color:rgba(199,168,120,.25)}

/* ANIMATE */
.rv{opacity:0;transform:translateY(22px);transition:opacity .75s ease,transform .75s ease}
.rv.in{opacity:1;transform:translateY(0)}

@media(max-width:960px){
  nav{padding:0 24px} .nl{display:none}
  .hero-inner{padding:60px 28px}
  .hero-stats{position:static;margin:40px 28px 0;grid-template-columns:1fr 1fr}
  .section-dark,.section-mid,.quote-section,.cta-final{padding:80px 28px}
  .process-grid,.diff-grid{grid-template-columns:1fr}
  .ft{padding:60px 28px;grid-template-columns:1fr 1fr;gap:36px}
  .fbo{padding:20px 28px;flex-direction:column;gap:8px}
}
</style>
